      </axis>
    </joint>

    <plugin filename="PriusDriveSystem" name="offroad_gazebo_integration::PriusDriveSystem">
      <drive_topic>/cmd_drive</drive_topic>
      <gear_topic>/cmd_gear</gear_topic>
      <wheel_base>2.86</wheel_base>
      <front_track_width>1.534</front_track_width>
      <wheel_radius>0.31265</wheel_radius>
      <max_steer>0.6458</max_steer>
      <max_speed>10.0</max_speed>
      <front_torque>859.4004393000001</front_torque>
      <back_torque>0.0</back_torque>
      <front_brake_torque>1031.28052716</front_brake_torque>
      <back_brake_torque>687.5203514400001</back_brake_torque>
      <flwheel_steering_p_gain>1e4</flwheel_steering_p_gain>
      <flwheel_steering_d_gain>3e2</flwheel_steering_d_gain>
      <drive_speed_gain>125.0</drive_speed_gain>
      <brake_damping_gain>800.0</brake_damping_gain>
      <steering_force_limit>2000.0</steering_force_limit>
    </plugin>

    <plugin filename="ignition-gazebo-odometry-publisher-system" name="ignition::gazebo::systems::OdometryPublisher">
      <odom_topic>/odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>
